# =========================================
# SK CPA COMMAND CENTER — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# On Render: add these in the Environment tab.
# =========================================

# --- Telegram ---
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- Postback security token ---
# Add ?secret=THIS_VALUE to every CPA network postback URL
# e.g. https://yourapp.onrender.com/postback?secret=abc123...&network={network}
POSTBACK_SECRET=change_this_to_a_long_random_string

# --- Dashboard login (HTTP Basic Auth) ---
# Leave DASHBOARD_PASS blank to disable auth (not recommended)
DASHBOARD_USER=admin
DASHBOARD_PASS=change_this_to_a_strong_password
